# Queens Custom Creations — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to GitHub

# ── PayPal ───────────────────────────────────────────────────────────────────
# Get these from: https://developer.paypal.com/dashboard/applications
# Create an app → Live → copy Client ID and Secret
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET_HERE
PAYPAL_ENV=live   # use 'sandbox' for testing, 'live' for real payments

# ── Email (AOL SMTP) ──────────────────────────────────────────────────────────
# AOL uses app passwords. Generate at: https://login.aol.com → Security → App Passwords
# OR use Gmail and generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_USER=wired4365@aol.com
SMTP_PASS=YOUR_AOL_APP_PASSWORD_HERE

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Sign up free at: https://www.twilio.com (free trial gives you $15 credit)
# Get your Account SID, Auth Token, and a Twilio phone number
TWILIO_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_FROM=+1XXXXXXXXXX   # Your Twilio phone number

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret for JWT tokens — use any long random string
JWT_SECRET=queens-custom-creations-change-this-to-something-random-2026
